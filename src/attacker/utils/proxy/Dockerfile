FROM envoyproxy/envoy:v1.32-latest@sha256:6bf0d37dd5e8eac4b37effe89a1aec4760f7f2ce860d1fd6af22147eb87a5058

ARG ENVOY_PORT="8080"
ARG OTEL_SERVICE_NAME="frontend-proxy"
ARG OTEL_COLLECTOR_HOST="otel-collector.mem"
ARG OTEL_COLLECTOR_PORT_GRPC="4317"
ARG OTEL_COLLECTOR_PORT_HTTP="4318"
ARG FRONTEND_HOST="frontend.app"
ARG FRONTEND_PORT="8080"
ARG IMAGE_PROVIDER_HOST="image-provider"
ARG IMAGE_PROVIDER_PORT="8081"
ARG FLAGD_HOST="flagd.mem"
ARG FLAGD_PORT="8013"
ARG FLAGD_UI_HOST="flagd.mem"
ARG FLAGD_UI_PORT="4000"
ARG GRAFANA_HOST="grafana.mem"
ARG GRAFANA_PORT="80"
ARG JAEGER_HOST="jaeger-query.mem"
ARG JAEGER_PORT="16686"
ARG OPENSEARCH_HOST="opensearch.mem"
ARG OPENSEARCH_PORT="9200"
ARG CALDERA_HOST="attacker"
ARG CALDERA_PORT="8080"

RUN apt-get update && apt-get install -y gettext-base=0.21-4ubuntu4 && apt-get clean && rm -rf /var/lib/apt/lists/*

USER envoy
WORKDIR /home/envoy
COPY envoy.tmpl.yaml envoy.tmpl.yaml

ENV ENVOY_PORT="$ENVOY_PORT" \
    OTEL_SERVICE_NAME="$OTEL_SERVICE_NAME" \
    OTEL_COLLECTOR_HOST="$OTEL_COLLECTOR_HOST" \
    OTEL_COLLECTOR_PORT_GRPC="$OTEL_COLLECTOR_PORT_GRPC" \
    OTEL_COLLECTOR_PORT_HTTP="$OTEL_COLLECTOR_PORT_HTTP" \
    FRONTEND_HOST="$FRONTEND_HOST" \
    FRONTEND_PORT="$FRONTEND_PORT" \
    IMAGE_PROVIDER_HOST="$IMAGE_PROVIDER_HOST" \
    IMAGE_PROVIDER_PORT="$IMAGE_PROVIDER_PORT" \
    FLAGD_HOST="$FLAGD_HOST" \
    FLAGD_PORT="$FLAGD_PORT" \
    FLAGD_UI_HOST="$FLAGD_UI_HOST" \
    FLAGD_UI_PORT="$FLAGD_UI_PORT" \
    GRAFANA_HOST="$GRAFANA_HOST" \
    GRAFANA_PORT="$GRAFANA_PORT" \
    JAEGER_HOST="$JAEGER_HOST" \
    JAEGER_PORT="$JAEGER_PORT" \
    OPENSEARCH_HOST="$OPENSEARCH_HOST" \
    OPENSEARCH_PORT="$OPENSEARCH_PORT" \
    CALDERA_HOST="$CALDERA_HOST" \
    CALDERA_PORT="$CALDERA_PORT"

ENTRYPOINT ["/bin/sh","-c","envsubst < envoy.tmpl.yaml > /tmp/envoy.yaml && envoy -c /tmp/envoy.yaml"]
